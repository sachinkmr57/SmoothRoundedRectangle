{"variants":[{"paths":["\/documentation\/smoothroundedrectangle"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Articles","identifiers":["doc:\/\/smoothroundedrectangle.SmoothRoundedRectangle\/documentation\/SmoothRoundedRectangle\/HighLevelDesign"],"anchor":"Articles","generated":true},{"title":"Structures","anchor":"Structures","identifiers":["doc:\/\/smoothroundedrectangle.SmoothRoundedRectangle\/documentation\/SmoothRoundedRectangle\/SmoothRoundedRectangle"],"generated":true}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"SmoothRoundedRectangle is a customizable SwiftUI shape that mimics Figma’s smooth corner rounding for rectangles. The smoothness value can be anything between 0 to 1, 0 with completely circular corner radius and 1 with full smoothness. Corners to which rounding has to be applied can be specified as well. The amount of rounding can be even more than half of the smaller dimension of rectangle just like in Figma.","type":"text"}]},{"type":"heading","anchor":"Essentials","level":2,"text":"Essentials"},{"type":"links","style":"compactGrid","items":["doc:\/\/smoothroundedrectangle.SmoothRoundedRectangle\/documentation\/SmoothRoundedRectangle\/HighLevelDesign"]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","identifier":{"url":"doc:\/\/smoothroundedrectangle.SmoothRoundedRectangle\/documentation\/SmoothRoundedRectangle","interfaceLanguage":"swift"},"abstract":[{"text":"A custom SwiftUI shape which mimics Figma’s smooth corner rounding for rectangles.","type":"text"}],"sections":[],"metadata":{"title":"SmoothRoundedRectangle","externalID":"SmoothRoundedRectangle","symbolKind":"module","modules":[{"name":"SmoothRoundedRectangle"}],"roleHeading":"Framework","role":"collection"},"references":{"doc://smoothroundedrectangle.SmoothRoundedRectangle/documentation/Smooth